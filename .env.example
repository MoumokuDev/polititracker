# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Database ---
# Used by docker compose to provision Postgres, and by the app/Alembic to connect.
POSTGRES_USER=polititracker
POSTGRES_PASSWORD=change-me
POSTGRES_DB=polititracker
# Host port the db container publishes on 127.0.0.1 (change if 5432 is taken)
POSTGRES_HOST_PORT=5432
# Connection string for app code running on the HOST (dev). Inside compose,
# services get a DATABASE_URL pointing at the `db` service instead.
# Use 127.0.0.1, not localhost — the port publish is IPv4-only and Windows
# hangs on the ::1 attempt.
DATABASE_URL=postgresql+psycopg://polititracker:change-me@127.0.0.1:5432/polititracker?connect_timeout=10

# --- API keys ---
# One api.data.gov key covers Congress.gov, GovInfo, and FEC.
# Sign up: https://api.data.gov/signup/
DATA_GOV_API_KEY=

# CourtListener REST API token (free account): https://www.courtlistener.com/
COURTLISTENER_API_TOKEN=

# --- Editing (promises, accountability records) ---
# ENABLE_EDITING=false turns the editing surface off entirely.
# With editing on, set EDITOR_PASSWORD on any shared/deployed instance:
# editing then requires login at /login. Leave empty only for local dev.
ENABLE_EDITING=true
EDITOR_PASSWORD=
# cookie-signing key (any long random string); falls back to EDITOR_PASSWORD
SECRET_KEY=
